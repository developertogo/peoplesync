#!/bin/bash

# Cleanup function to kill background processes on exit
cleanup() {
  echo ""
  echo "Stopping Peoplesync system..."
  if [ -n "$BACKEND_PID" ]; then
    kill $BACKEND_PID 2>/dev/null || true
  fi
  if [ -n "$FRONTEND_PID" ]; then
    kill $FRONTEND_PID 2>/dev/null || true
  fi
  exit 0
}

# Trap Ctrl+C (SIGINT) and SIGTERM
trap cleanup SIGINT SIGTERM

# Navigate to monorepo root if necessary, or just run the monorepo scripts
cd "$(dirname "$0")/.."

# Check if --local flag is provided as an argument
USE_LOCAL="false"
for arg in "$@"; do
  if [ "$arg" = "--local" ]; then
    USE_LOCAL="true"
  fi
done

# If environment variable USE_LOCAL_DB_JSON is already set, respect it
if [ "$USE_LOCAL_DB_JSON" = "true" ]; then
  USE_LOCAL="true"
fi

echo "Starting Peoplesync Backend (MCP Server)..."
npm run mcp:start &
BACKEND_PID=$!

echo "Starting Peoplesync Frontend (Vite)..."
# Inject VITE_USE_LOCAL_DB_JSON env variable into Vite environment
VITE_USE_LOCAL_DB_JSON=$USE_LOCAL npm run web:dev &
FRONTEND_PID=$!

echo "===================================================="
echo "Peoplesync system started successfully! (Local DB Mode: $USE_LOCAL)"
echo "Press Ctrl+C to stop both services."
echo "===================================================="

# Keep the script running to hold the trap active
wait
