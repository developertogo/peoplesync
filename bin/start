#!/bin/bash

# Cleanup function to kill background processes on exit
cleanup() {
  echo ""
  echo "Stopping Peoplesync system..."
  if [ -n "$BACKEND_PID" ]; then
    kill $BACKEND_PID 2>/dev/null || true
  fi
  if [ -n "$FRONTEND_PID" ]; then
    kill $FRONTEND_PID 2>/dev/null || true
  fi
  exit 0
}

# Trap Ctrl+C (SIGINT) and SIGTERM
trap cleanup SIGINT SIGTERM

# Navigate to monorepo root if necessary, or just run the monorepo scripts
cd "$(dirname "$0")/.."

echo "Starting Peoplesync Backend (MCP Server)..."
npm run mcp:start &
BACKEND_PID=$!

echo "Starting Peoplesync Frontend (Vite)..."
npm run web:dev &
FRONTEND_PID=$!

echo "===================================================="
echo "Peoplesync system started successfully!"
echo "Press Ctrl+C to stop both services."
echo "===================================================="

# Keep the script running to hold the trap active
wait
